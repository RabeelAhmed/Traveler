VITE_SERVER_BASE_URL=https://traveler-server-xxxx.b4a.run
VITE_TRAVEL_ADVISOR_BASE_URL=https://traveler-agent.vercel.app
VITE_WEATHER_API_KEY=your_tomorrow_io_api_key

# ─── Socket.IO Feature Flag ───────────────────────────────────────────────────
# Set to "false" on Vercel deployments (serverless, no WebSocket support).
# Set to "true" when migrating to a host that supports persistent connections
# (e.g., Railway, Render, Fly.io). No code changes needed — just toggle this.
VITE_SOCKET_IO_ENABLED=false
